# RAID Nexus environment template. Copy to .env and replace placeholders.

# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/raidnexus
POSTGRES_URL=
POSTGRES_DB=raidnexus
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
RAID_NEXUS_DB_PATH=./backend/raid_nexus.db
RAID_NEXUS_TRAINING_DATA_PATH=
RAID_FORCE_SQLITE=false

# Security and auth
SECRET_KEY=replace-with-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-admin-password
USER_USERNAME=user
USER_PASSWORD=replace-with-user-password
CORS_ORIGINS=http://localhost:5173
CORS_ORIGIN_REGEX=

# AI, ML, and optional LLMs
MODEL_PATH=./ml/models/dispatch_model.pkl
USE_LLM=false
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OPENROUTER_API_KEY=
ENABLE_NLP_TRIAGE=false
ENABLE_TRANSLATION=false
ENABLE_ANOMALY_DETECTION=true
RAID_LIGHTWEIGHT_TRIAGE=true
RAID_DISABLE_SIMULATION=false
RAID_NEXUS_USE_GRAPH_PIPELINE=false

# Routing and maps
TOMTOM_API_KEY=
OSRM_URL=http://router.project-osrm.org
RAID_DISABLE_EXTERNAL_ROUTING=false
RAID_DISABLE_ROUTE_GEOMETRY=false
RAID_ENABLE_ALTERNATE_ROUTE_GEOMETRY=false

# Frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/live
VITE_WS_BASE_URL=
VITE_ENV=development
