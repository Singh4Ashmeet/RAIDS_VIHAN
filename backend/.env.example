# RAID Nexus environment template
# Copy this file to backend/.env for local development.
# Do not commit backend/.env or any real secret values.

# Authentication
SECRET_KEY=change-this-to-a-random-64-char-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
USER_USERNAME=user
USER_PASSWORD=change-this-user-password

# Database
# If DATABASE_URL is unset, RAID Nexus uses local SQLite at backend/raid_nexus.db.
# Use a managed PostgreSQL URL from Neon, Supabase, or another Postgres host in production.
DATABASE_URL=
POSTGRES_URL=
RAID_POSTGRES_POOL_SIZE=5
RAID_FORCE_SQLITE=0
RAID_NEXUS_DB_PATH=

# Runtime mode
# Use lightweight triage on small/free hosting plans to avoid loading large NLP models.
RAID_LIGHTWEIGHT_TRIAGE=1
RAID_DISABLE_SIMULATION=1

# Hugging Face model cache
HF_HOME=.cache/huggingface
TRANSFORMERS_CACHE=.cache/huggingface
PYTHONUNBUFFERED=1

# Optional generated ML data override
RAID_NEXUS_TRAINING_DATA_PATH=
