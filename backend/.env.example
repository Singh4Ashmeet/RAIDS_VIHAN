# Backend environment template. Copy to backend/.env for local backend-only runs.

ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./raid_nexus.db
POSTGRES_URL=
RAID_NEXUS_DB_PATH=./raid_nexus.db
RAID_NEXUS_TRAINING_DATA_PATH=
RAID_FORCE_SQLITE=false

SECRET_KEY=replace-with-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-admin-password
USER_USERNAME=user
USER_PASSWORD=replace-with-user-password
CORS_ORIGINS=http://localhost:5173
CORS_ORIGIN_REGEX=

MODEL_PATH=./ml/models/dispatch_model.pkl
USE_LLM=false
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OPENROUTER_API_KEY=
ENABLE_NLP_TRIAGE=false
ENABLE_TRANSLATION=false
ENABLE_ANOMALY_DETECTION=true
RAID_LIGHTWEIGHT_TRIAGE=true
RAID_DISABLE_SIMULATION=false
RAID_SKIP_STARTUP_MIGRATIONS=false
RAID_NEXUS_USE_GRAPH_PIPELINE=false

TOMTOM_API_KEY=
OSRM_URL=http://router.project-osrm.org
RAID_DISABLE_EXTERNAL_ROUTING=false
RAID_DISABLE_ROUTE_GEOMETRY=false
RAID_ENABLE_ALTERNATE_ROUTE_GEOMETRY=false
