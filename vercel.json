{
  "framework": "vite",
  "installCommand": "cd frontend && npm ci",
  "buildCommand": "cd frontend && VITE_WS_BASE_URL=https://raid-nexus.onrender.com npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://raid-nexus.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://raid-nexus.onrender.com/ws/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
